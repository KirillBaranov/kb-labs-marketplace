{
  "name": "@kb-labs/marketplace-cli",
  "version": "0.1.2",
  "description": "Marketplace CLI plugin — commands for managing plugins, adapters, and other marketplace entities",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin-manifest": {
      "import": "./dist/manifest.js"
    }
  },
  "kb": {
    "manifest": "./dist/manifest.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests -c ../../vitest.config.ts"
  },
  "dependencies": {
    "@kb-labs/sdk": "link:../../../kb-labs-sdk/packages/sdk"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vitest": "^3.2.4",
    "@kb-labs/devkit": "link:../../../../infra/kb-labs-devkit",
    "@types/node": "^24.3.3"
  }
}
