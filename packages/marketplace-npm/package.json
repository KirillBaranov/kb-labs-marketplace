{
  "name": "@kb-labs/marketplace-npm",
  "version": "0.1.2",
  "description": "npm/pnpm package source for KB Labs marketplace",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests -c ../../vitest.config.ts",
    "test:watch": "vitest -c ../../vitest.config.ts"
  },
  "dependencies": {
    "@kb-labs/marketplace-contracts": "workspace:*",
    "execa": "^9.5.3"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vitest": "^3.2.4",
    "@kb-labs/devkit": "link:../../../../infra/kb-labs-devkit"
  }
}
