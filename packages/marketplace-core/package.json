{
  "name": "@kb-labs/marketplace-core",
  "version": "0.1.3",
  "description": "Marketplace service — unified install/uninstall/enable/disable for all entity types",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests -c ../../vitest.config.ts",
    "test:watch": "vitest -c ../../vitest.config.ts"
  },
  "dependencies": {
    "@kb-labs/marketplace-contracts": "workspace:*",
    "@kb-labs/core-discovery": "link:../../../kb-labs-core/packages/core-discovery",
    "@kb-labs/core-platform": "link:../../../kb-labs-core/packages/core-platform",
    "@kb-labs/plugin-contracts": "link:../../../../infra/kb-labs-plugin/packages/plugin-contracts",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vitest": "^3.2.4",
    "@kb-labs/devkit": "link:../../../../infra/kb-labs-devkit"
  }
}
